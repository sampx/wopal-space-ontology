# AI Toolbox Environment Configuration
# Copy this file to .env and fill in your API keys

# Tavily API Key (Required for search/research skills)
# Get one at https://tavily.com/
TAVILY_API_KEY=tvly-dev-sk-xxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (Optional, depending on skills used)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (Optional, depending on skills used)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Wopal Plugin Logging
# Log level: error | warn | info | debug | trace (default: warn)
WOPAL_PLUGIN_LOG_LEVEL=warn
# Module filter: comma-separated module names, empty = no filter
WOPAL_PLUGIN_LOG_MODULES=
