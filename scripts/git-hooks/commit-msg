#!/bin/bash
#
# Git commit-msg hook: validate commit message format
# Follows Conventional Commits specification
#

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Get the first line (title line)
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n1)

# Valid commit types
VALID_TYPES="feat|fix|refactor|docs|test|chore|enhance|style|perf|ci|build|revert"

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Validation function
validate_commit_message() {
    local msg="$1"
    
    # Check if empty
    if [ -z "$msg" ]; then
        echo -e "${RED}Error: commit message cannot be empty${NC}"
        return 1
    fi
    
    # Check for colon separator
    if ! echo "$msg" | grep -q ': '; then
        echo -e "${RED}Error: commit message missing colon separator${NC}"
        echo ""
        echo -e "${YELLOW}Format: <type>: <description>${NC}"
        echo -e "${YELLOW}Note: a space is required after the colon${NC}"
        echo ""
        echo -e "${RED}Your message:${NC}"
        echo "  $msg"
        return 1
    fi
    
    # Extract type and description
    local type=$(echo "$msg" | sed -E 's/^([a-z]+)(\([^)]+\))?: .*/\1/')
    local description=$(echo "$msg" | sed -E 's/^[^:]+: //')
    
    # Check if type is valid
    if ! echo "$type" | grep -qE "^(${VALID_TYPES})$"; then
        echo -e "${RED}Error: commit type '${type}' is invalid${NC}"
        echo ""
        echo -e "${YELLOW}Valid types:${NC}"
        echo "  feat     - New feature"
        echo "  fix      - Bug fix"
        echo "  refactor - Refactor (no functional change)"
        echo "  docs     - Documentation"
        echo "  test     - Testing"
        echo "  chore    - Build/tools"
        echo "  enhance  - Enhancement"
        echo "  style    - Code formatting (no logic change)"
        echo "  perf     - Performance improvement"
        echo "  ci       - CI/CD config"
        echo "  build    - Build system"
        echo "  revert   - Revert commit"
        echo ""
        echo -e "${RED}Your message:${NC}"
        echo "  $msg"
        return 1
    fi
    
    # Check if description is empty
    if [ -z "$description" ]; then
        echo -e "${RED}Error: description is empty${NC}"
        echo ""
        echo -e "${YELLOW}Format: <type>: <description>${NC}"
        echo -e "${YELLOW}description cannot be empty${NC}"
        echo ""
        echo -e "${RED}Your message:${NC}"
        echo "  $msg"
        return 1
    fi
    
    # Check description length (max 60 chars)
    local desc_len=${#description}
    if [ $desc_len -gt 60 ]; then
        echo -e "${RED}Error: description too long (${desc_len} chars, max 60)${NC}"
        echo ""
        echo -e "${YELLOW}Suggestion:${NC}"
        echo "  Shorten the description or move details to the body"
        echo ""
        echo -e "${RED}Your message:${NC}"
        echo "  $msg"
        echo -e "${YELLOW}Description:${NC}"
        echo "  $description"
        return 1
    fi
    
    # Check total first line length (max 72 chars)
    local total_len=${#msg}
    if [ $total_len -gt 72 ]; then
        echo -e "${RED}Error: first line too long (${total_len} chars, max 72)${NC}"
        echo ""
        echo -e "${YELLOW}Suggestion:${NC}"
        echo "  Move detailed description to the body (after a blank line)"
        echo ""
        echo -e "${RED}Your message:${NC}"
        echo "  $msg"
        return 1
    fi
    
    return 0
}

# Run validation
if validate_commit_message "$FIRST_LINE"; then
    exit 0
else
    exit 1
fi